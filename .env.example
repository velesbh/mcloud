# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Free Tier Limits (overrideable per deployment)
FREE_TIER_MAX_SERVERS=1
FREE_TIER_RAM_MB=1024
FREE_TIER_DISK_MB=5120
FREE_TIER_CPU_PERCENT=100

# S3-compatible Storage (optional — falls back to Supabase Storage if unset)
# Works with AWS S3, Cloudflare R2, MinIO, or any S3-compatible provider
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=mcloud-files
S3_ACCESS_KEY=your_access_key_id
S3_SECRET_KEY=your_secret_access_key
# S3_FORCE_PATH_STYLE=true   # uncomment for MinIO / self-hosted

# App
NEXT_PUBLIC_APP_URL=https://mcloud.enzonic.com
NEXT_PUBLIC_APP_NAME=MCloud
ADMIN_EMAIL=admin@enzonic.com
MODRINTH_USER_AGENT=MCloud/1.0 (admin@enzonic.com)
