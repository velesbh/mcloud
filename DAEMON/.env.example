# Daemon identity — must match a row in the `nodes` table
NODE_ID=

# Supabase (use SERVICE_ROLE — daemon is fully trusted)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Where to put server files on disk
SERVERS_DIR=/var/lib/mcloud/servers

# Java to use (allow auto-pick by MC version later)
JAVA_BIN=java

# Bedrock binary path (optional)
BEDROCK_BIN=

# S3-compatible Storage (optional — falls back to Supabase Storage if unset)
# Must match the values set in the main app's .env
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=mcloud-files
S3_ACCESS_KEY=your_access_key_id
S3_SECRET_KEY=your_secret_access_key
# S3_FORCE_PATH_STYLE=true   # uncomment for MinIO / self-hosted

# Logging
LOG_LEVEL=info
